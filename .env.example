# Required for any trading action
POLYGON_WALLET_PRIVATE_KEY=
# Optional: if you trade from a proxy/email wallet, this is the funder address
POLYGON_FUNDER_ADDRESS=
# Optional: override the default L2 host (mainnet)
CLOB_API_URL=https://clob.polymarket.com
# Optional: override the default Gamma host
GAMMA_API_URL=https://gamma-api.polymarket.com
# Optional: switch to Polygon Amoy testnet (set to 80002 for paper trading)
POLYBOT_CHAIN_ID=137

# Bot runtime
POLYBOT_BUDGET_USDC=100
POLYBOT_MAX_POSITION_USDC=5
POLYBOT_MAX_DAILY_LOSS_USDC=25
POLYBOT_LOG_LEVEL=INFO
POLYBOT_DB_URL=sqlite:///./polybot.db

# Telegram backend mode
POLYBOT_TELEGRAM_BOT_TOKEN=
# When running --serve, bind here
POLYBOT_HOST=0.0.0.0
POLYBOT_PORT=8080

# Optional: news-edge strategy
OPENAI_API_KEY=
NEWS_API_KEY=
